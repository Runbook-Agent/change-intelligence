# Change Intelligence Service — Environment Variables
# Copy to .env and customize

# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Storage
CHANGE_INTEL_DB_PATH=changes.db

# Auth for protected mutation/admin endpoints (recommended for all non-local deployments)
# CHANGE_INTEL_ADMIN_TOKEN=replace-with-long-random-token

# Service graph (optional - path to YAML graph definition)
# CHANGE_INTEL_GRAPH_PATH=graph.yaml

# Webhook verification/auth secrets (optional but strongly recommended in production)
# GITHUB_WEBHOOK_SECRET=your-secret-here
# GITLAB_WEBHOOK_SECRET=your-secret-here
# TERRAFORM_WEBHOOK_SECRET=your-secret-here
# AGENT_WEBHOOK_SECRET=your-secret-here
# K8S_WEBHOOK_SECRET=your-secret-here
# AWS_WEBHOOK_SECRET=your-secret-here
